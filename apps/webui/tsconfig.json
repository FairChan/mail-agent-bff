{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@mail-agent/shared-types": ["../../packages/shared-types/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "references": [
    { "path": "../../packages/shared-types" }
  ]
}
