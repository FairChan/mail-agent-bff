{
  "openapi": "3.0.3",
  "info": {
    "title": "Mery BFF API",
    "description": "TrueSight Email AI Assistant Backend-for-Frontend API",
    "version": "1.0.0",
    "contact": {
      "name": "TrueSight Team",
      "email": "dev@true-sight.asia"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "https://bff.true-sight.asia",
      "description": "Production"
    },
    {
      "url": "https://staging.true-sight.asia",
      "description": "Staging"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local Development"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "Mail",
      "description": "Email operations"
    },
    {
      "name": "Calendar",
      "description": "Calendar operations"
    },
    {
      "name": "Health",
      "description": "Health check endpoints"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns the health status of all services",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service is unhealthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/metrics": {
      "get": {
        "tags": ["Health"],
        "summary": "Prometheus metrics",
        "description": "Returns Prometheus-formatted metrics",
        "operationId": "getMetrics",
        "security": [],
        "responses": {
          "200": {
            "description": "Metrics data",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register new user",
        "description": "Creates a new user account",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "description": "Authenticates user and returns session",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "Session cookie"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/mail/query": {
      "get": {
        "tags": ["Mail"],
        "summary": "Query emails",
        "description": "Retrieves emails from the mailbox",
        "operationId": "queryMail",
        "security": [{ "session": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "description": "Maximum number of emails to return"
          },
          {
            "name": "folder",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["inbox", "sent", "drafts", "archive", "trash"],
              "default": "inbox"
            },
            "description": "Mail folder"
          },
          {
            "name": "sourceId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Mail source identifier"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Email list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MailQueryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/api/mail/ai-summary": {
      "post": {
        "tags": ["Mail"],
        "summary": "Generate AI summary",
        "description": "Generates an AI-powered summary of emails",
        "operationId": "generateAiSummary",
        "security": [{ "session": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiSummaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI summary generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiSummaryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "504": {
            "description": "AI service timeout"
          }
        }
      }
    },
    "/api/mail/calendar/sync": {
      "post": {
        "tags": ["Calendar"],
        "summary": "Sync calendar",
        "description": "Synchronizes calendar events",
        "operationId": "syncCalendar",
        "security": [{ "session": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalendarSyncRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Calendar synced",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CalendarSyncResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "bff_session",
        "description": "Session cookie from login"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["healthy", "degraded", "unhealthy"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "services": {
            "type": "object",
            "properties": {
              "redis": {
                "$ref": "#/components/schemas/ServiceStatus"
              },
              "prisma": {
                "$ref": "#/components/schemas/ServiceStatus"
              },
              "gateway": {
                "$ref": "#/components/schemas/ServiceStatus"
              }
            }
          },
          "uptime": {
            "type": "integer",
            "description": "Process uptime in seconds"
          }
        }
      },
      "ServiceStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["up", "down", "disabled"]
          },
          "latencyMs": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "code"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "format": "password"
          },
          "code": {
            "type": "string",
            "description": "Email verification code",
            "minLength": 6,
            "maxLength": 6
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": "string"
          },
          "locale": {
            "type": "string",
            "enum": ["zh-CN", "en-US", "ja-JP"]
          }
        }
      },
      "MailQueryResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "total": {
            "type": "integer"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Email"
            }
          }
        }
      },
      "Email": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "from": {
            "$ref": "#/components/schemas/EmailAddress"
          },
          "to": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmailAddress"
            }
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time"
          },
          "hasAttachments": {
            "type": "boolean"
          },
          "isRead": {
            "type": "boolean"
          },
          "importance": {
            "type": "string",
            "enum": ["low", "normal", "high"]
          },
          "bodyPreview": {
            "type": "string",
            "maxLength": 200
          }
        }
      },
      "EmailAddress": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "AiSummaryRequest": {
        "type": "object",
        "required": ["sourceId"],
        "properties": {
          "sourceId": {
            "type": "string"
          },
          "userQuery": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10
          }
        }
      },
      "AiSummaryResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "summary": {
            "type": "string"
          },
          "emailCount": {
            "type": "integer"
          }
        }
      },
      "CalendarSyncRequest": {
        "type": "object",
        "properties": {
          "sourceId": {
            "type": "string"
          }
        }
      },
      "CalendarSyncResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "eventsAdded": {
            "type": "integer"
          },
          "eventsUpdated": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "details": {
            "type": "object",
            "description": "Additional error details"
          }
        }
      }
    }
  }
}