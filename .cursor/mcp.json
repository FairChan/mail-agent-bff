{
  "mcpServers": {
    "openclaw-gateway": {
      "command": "npx",
      "args": ["-y", "openclaw-mcp"],
      "env": {
        "OPENCLAW_GATEWAY_URL": "http://127.0.0.1:18789",
        "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}"
      }
    },
    "openclaw-molt-mcp": {
      "command": "/root/openclaw-molt-mcp/.venv/bin/python",
      "args": ["-m", "openclaw_molt_mcp"],
      "env": {
        "PYTHONPATH": "/root/openclaw-molt-mcp/src",
        "PYTHONUNBUFFERED": "1",
        "OPENCLAW_GATEWAY_URL": "http://127.0.0.1:18789",
        "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}"
      }
    },
    "openclaw-cursor-brain": {
      "command": "node",
      "args": ["/root/openclaw-cursor-brain/mcp-server/server.mjs"],
      "env": {
        "OPENCLAW_GATEWAY_URL": "http://127.0.0.1:18789",
        "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
        "OPENCLAW_CONFIG_PATH": "/root/.openclaw/openclaw.json"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "/Users/fairchan/Desktop/mail-agent-bff"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.70",
        "--headless",
        "--isolated",
        "--output-dir",
        "/Users/fairchan/Desktop/mail-agent-bff/.harness/tmp/playwright-mcp"
      ]
    },
    "magicui-mcp": {
      "command": "node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/@magicuidesign/mcp/dist/server.js"
      ]
    },
    "reactbits-mcp": {
      "command": "node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/reactbits-dev-mcp-server/dist/index.js"
      ]
    }
  }
}
