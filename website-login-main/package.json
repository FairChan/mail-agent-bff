{
  "name": "mailpilot-auth-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:bff\"",
    "dev:web": "vite",
    "dev:bff": "tsx watch bff/src/server.ts",
    "build": "npm run build:web && npm run build:bff",
    "build:web": "tsc && vite build",
    "build:bff": "tsc -p bff/tsconfig.json",
    "preview": "vite preview",
    "start": "node bff/dist/server.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "typescript": "~5.9.3",
    "tsx": "^4.20.5",
    "vite": "^8.0.1"
  }
}
