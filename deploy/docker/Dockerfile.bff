FROM node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/shared-types/package.json packages/shared-types/package.json
COPY apps/bff/package.json apps/bff/package.json

RUN npm ci --include=dev

FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared-types/package.json ./packages/shared-types/package.json
COPY --from=deps /app/apps/bff/package.json ./apps/bff/package.json
COPY package.json package-lock.json ./
COPY packages/shared-types ./packages/shared-types
COPY apps/bff ./apps/bff

RUN cd apps/bff && npx prisma generate --schema prisma/schema.prisma
RUN npm --workspace apps/bff run build

FROM node:20-alpine AS production

WORKDIR /app

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=8787

RUN apk add --no-cache curl

COPY --from=builder /app/package.json /app/package-lock.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/bff/package.json ./apps/bff/package.json
COPY --from=builder /app/apps/bff/dist ./apps/bff/dist
COPY --from=builder /app/apps/bff/prisma ./apps/bff/prisma
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma

RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001
RUN chown -R nodejs:nodejs /app
USER nodejs

EXPOSE 8787

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
  CMD curl -fsS http://127.0.0.1:8787/api/ready >/dev/null || exit 1

CMD ["sh", "-c", "cd apps/bff && npx prisma migrate deploy --schema prisma/schema.prisma && cd /app && node apps/bff/dist/server.js"]
